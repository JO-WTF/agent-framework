# Copy this file to .env and replace the placeholder values.
# Never commit your real .env file or API keys.

# LLM provider: openai, deepseek, ollama, llamacpp, or another OpenAI-compatible provider.
LLM_PROVIDER=openai

# Model name for the selected provider.
# Examples: gpt-4o-mini, deepseek-chat, llama3.1
LLM_MODEL_NAME=gpt-4o-mini

# Generic API key used by most providers in this project.
LLM_API_KEY=replace-with-your-llm-api-key

# Optional provider-specific API keys.
# OPENAI_API_KEY is used as a fallback when LLM_PROVIDER=openai and LLM_API_KEY is empty.
OPENAI_API_KEY=
# DEEPSEEK_API_KEY is used as a fallback when LLM_PROVIDER=deepseek and LLM_API_KEY is empty.
DEEPSEEK_API_KEY=

# Optional OpenAI-compatible base URL override.
# Leave empty for OpenAI defaults. DeepSeek, Ollama, and llama.cpp have defaults in app/config.py.
LLM_BASE_URL=

# Model temperature. Lower values are more deterministic.
LLM_TEMPERATURE=0.1

# Maximum serialized conversation context size in KB.
MAX_CONTEXT_SIZE_KB=512

# Tavily search API key. Required only when using the search tool.
TAVILY_API_KEY=replace-with-your-tavily-api-key
